# Python Cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments
.venv/
venv/
ENV/
env/

# Environment configurations (always ignore secrets, but commit templates)
**/.env
**/.env.*
!**/.env.example
!**/.env.template

# IDEs and Editors
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Logs
*.log

# Testing and Coverage
.pytest_cache/
.mypy_cache/
.ruff_cache/
.tox/
.coverage
.coverage.*
htmlcov/
nosetests.xml
coverage.xml
*.cover

# Database & local sqlite files
*.db
*.sqlite3
chroma/
.chroma/

# Uploaded assets (keep folders but ignore user content)
**/uploads/*
!**/uploads/.gitkeep

# React Frontend dependencies and builds
**/node_modules/
**/dist/

# Scratch & temporary workspace folders
scratch/
